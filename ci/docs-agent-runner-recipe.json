{
  "id": "docs-agent/codebox-agent-bundle",
  "description": "Docs Agent runtime recipe for the Homeboy Extensions Codebox agent-bundle profile contract.",
  "runtime_provider": "wp-codebox",
  "runtime_ref": "main",
  "runtime_profile": "docs-agent-codebox-bundle",
  "runtime_profiles": {
    "docs-agent-codebox-bundle": {
      "schema": "wp-codebox/runtime-profile/v1",
      "id": "docs-agent-codebox-bundle",
      "runtime_task_ability": "datamachine/run-agent-bundle",
      "runtime_bundle_ability": "datamachine/run-agent-bundle",
      "runtime_workflow_ability": "datamachine/execute-workflow",
      "ability_requirements": [
        "datamachine/run-agent-bundle"
      ],
      "metadata": {
        "owner": "Automattic/docs-agent",
        "contract": "Codebox imports the selected Docs Agent bundle and invokes the bundle runtime ability. Host-side writable scope is declared through the reusable workflow writable_paths input."
      }
    }
  },
  "runtime_dependencies": [
    "Automattic/agents-api@main",
    "Extra-Chill/data-machine@main",
    "Extra-Chill/data-machine-code@main"
  ],
  "openai_provider_ref": "trunk",
  "runtime_components": {
    "agents_api": "${github_workspace}/.ci/agents-api",
    "data_machine": "${github_workspace}/.ci/data-machine",
    "data_machine_code": "${github_workspace}/.ci/data-machine-code"
  },
  "ability_requirements": [
    "datamachine/run-agent-bundle"
  ],
  "runtime_config": {
    "daily_memory_enabled": false,
    "disable_datamachine_directives": false,
    "enable_terminal_actions": false,
    "wp_cli_tool_name": "run_wp_cli",
    "pipeline_step_patches": [],
    "flow_step_patches": [],
    "wp_gym_eval": {
      "benchmark_mode": false
    }
  }
}
