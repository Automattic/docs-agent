{
  "component_id": "docs-agent-ci-driver",
  "component_path": "/path/to/consumer/component",
  "workload_id": "technical-docs-generation",
  "workload_label": "Run Docs Agent",
  "validation_dependencies": [
    "/path/to/agents-api",
    "/path/to/data-machine",
    "/path/to/data-machine-code",
    "/path/to/ai-provider-for-openai"
  ],
  "playground_wordpress_version": "7.0",
  "bundle_repo": "https://github.com/Automattic/docs-agent.git",
  "bundle_ref": "main",
  "bundle_path_in_repo": "bundles/docs-agent",
  "agent_slug": "docs-agent",
  "pipeline_slug": "technical-docs-pipeline",
  "flow_slug": "technical-docs-maintenance-flow",
  "provider": "openai",
  "model": "gpt-5.5",
  "provider_register_function": "WordPress\\OpenAiAiProvider\\register_provider",
  "provider_credentials": {
    "connectors_ai_openai_api_key": "OPENAI_API_KEY"
  },
  "github_token_env": "GITHUB_TOKEN",
  "github_profile_id": "docs-agent-ci",
  "target_repo": "OWNER/REPO",
  "allowed_repos": ["OWNER/REPO"],
  "runner_workspace": {
    "enabled": true,
    "repo": "REPO",
    "clone_url": "https://github.com/OWNER/REPO.git",
    "branch_prefix": "docs/agent-run",
    "from": "origin/main",
    "bootstrap": false
  },
  "success_requires_pr": false,
  "max_turns": 12,
  "prompt": "Run the technical docs maintenance flow. Update developer-facing living documentation only where source code, tests, recent issues, recent pull requests, or existing docs show stale, missing, fragmented, or misleading coverage. Open a documentation PR only if needed.",
  "step_budget": 16,
  "time_budget_ms": 600000,
  "transcript_dir": "/wordpress/wp-content/plugins/docs-agent-ci-driver/artifacts/docs-agent",
  "required_abilities": [
    "datamachine/import-agent",
    "datamachine/run-flow",
    "datamachine/drain-job",
    "datamachine/workspace-worktree-add"
  ],
  "tool_recorders": [
    {
      "tool": "create_github_pull_request",
      "record": {
        "engine_key": "docs_agent",
        "tool_results_key": "github_tool_results",
        "event": {
          "key": "pr",
          "type": "pull_request",
          "only_if_success": true
        }
      }
    }
  ],
  "bench_env": {
    "GITHUB_TOKEN": "${GITHUB_TOKEN}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}"
  }
}
